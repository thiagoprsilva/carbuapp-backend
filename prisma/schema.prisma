generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Oficina {
  id          Int       @id @default(autoincrement())
  nome        String
  responsavel String
  telefone    String
  endereco    String
  logoUrl     String?   // caminho relativo: "logos/oficina-1.png"
  createdAt   DateTime  @default(now())

  usuarios    Usuario[]
  clientes    Cliente[]
  veiculos    Veiculo[]
  registros   RegistroTecnico[]
  orcamentos  Orcamento[]
}

model Usuario {
  id         Int      @id @default(autoincrement())
  nome       String
  email      String   @unique
  senha      String
  role       String   // "superadmin" | "admin" | "mecanico"
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())

  // null apenas para o superadmin global (sem vínculo com oficina)
  oficinaId  Int?
  oficina    Oficina? @relation(fields: [oficinaId], references: [id])
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String?
  createdAt DateTime @default(now())

  oficinaId Int
  oficina   Oficina  @relation(fields: [oficinaId], references: [id])

  veiculos  Veiculo[]
}

model Veiculo {
  id          Int      @id @default(autoincrement())
  placa       String
  modelo      String
  ano         String?
  motor       String?
  alimentacao String?
  createdAt   DateTime @default(now())

  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])

  oficinaId   Int
  oficina     Oficina  @relation(fields: [oficinaId], references: [id])

  registros   RegistroTecnico[]
  orcamentos  Orcamento[]
}

model RegistroTecnico {
  id          Int      @id @default(autoincrement())
  categoria   String
  descricao   String
  dataServico DateTime
  observacoes String?
  createdAt   DateTime @default(now())

  veiculo     Veiculo  @relation(fields: [veiculoId], references: [id])
  veiculoId   Int

  oficina     Oficina  @relation(fields: [oficinaId], references: [id])
  oficinaId   Int

// vinculo opcional com orçamento
  orcamentoId Int?
  orcamento Orcamento? @relation(fields: [orcamentoId], references: [id])
  
}
model Orcamento {
  id        Int      @id @default(autoincrement())
  numero    Int
  status    String   @default("Pendente")
  subtotal  Float?
  total     Float?
  createdAt DateTime @default(now())

  veiculoId Int
  veiculo   Veiculo  @relation(fields: [veiculoId], references: [id])

  oficinaId Int
  oficina   Oficina  @relation(fields: [oficinaId], references: [id])

  itens     OrcamentoItem[]

  @@unique([oficinaId, numero])


  // lista de registros gerados a partir dele
  registrosTecnicos RegistroTecnico[]

}

model OrcamentoItem {
  id           Int     @id @default(autoincrement())
  descricao    String
  qtd          Int
  precoUnit    Float?
  valorLinha   Float?

  orcamentoId  Int
  orcamento    Orcamento @relation(fields: [orcamentoId], references: [id])
}