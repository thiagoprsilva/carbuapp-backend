# ============================================================
# CarbuApp Backend – Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no git.
# ============================================================

# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
POSTGRES_USER=carbuapp
POSTGRES_PASSWORD=<senha-forte-aqui>
POSTGRES_DB=carbuapp

# ⚠️ Atenção: o HOST muda dependendo do ambiente:
#   - Rodando LOCAL (sem Docker): use localhost
#     DATABASE_URL="postgresql://carbuapp:<senha>@localhost:5432/carbuapp?schema=public"
#   - Rodando na VPS (dentro do Docker): use db (nome do serviço no docker-compose)
#     DATABASE_URL="postgresql://carbuapp:<senha>@db:5432/carbuapp?schema=public"
DATABASE_URL="postgresql://carbuapp:<senha-forte-aqui>@localhost:5432/carbuapp?schema=public"

# JWT – use um segredo longo e aleatório
# Gere um com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<gere-um-segredo-aleatorio-aqui>

# Porta do servidor
PORT=3333

# Senha usada pelo seed para criar os usuários admin iniciais
# Defina uma senha forte antes de rodar o seed
SEED_ADMIN_PASSWORD=<senha-forte-para-o-admin>
